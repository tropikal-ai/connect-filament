{
    "name": "tropikal-ai/connect-filament",
    "description": "TROPIKAL Connect integration for Laravel Filament.",
    "keywords": [
        "filament",
        "laravel",
        "oauth",
        "connect"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Tropikal AI"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.2",
        "laravel/framework": "^11.0|^12.0",
        "tropikal-ai/connect": "dev-main"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^9.0|^10.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../connect",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "TropikalAI\\ConnectFilament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TropikalAI\\ConnectFilament\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TropikalAI\\ConnectFilament\\ConnectFilamentServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "format": "pint",
        "test": "phpunit --colors=never"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
